# Make the declared Node floor (package.json engines) a HARD failure at install time.
# CP-7 run 4 (K3): a green preflight on Node 20.10 let `npm ci` proceed with only an EBADENGINE
# warning; the failure then surfaced as `node:util.styleText` inside Rolldown — illegible at the
# point of failure — and that truncated install caused K5 (a missing optional native package).
#
# This file is the CLI archetype's copy of the service scaffold's guard. Both archetypes declare
# `engines.node >= 24` and ship .nvmrc/.node-version; an adopter who takes THIS one must get the
# same hard failure, or the fix only covers half the profile.
#
# Blast radius (know this before you hit it): npm applies engine-strict to EVERY package's `engines`,
# not just this project's. A dependency that has not declared support for your Node version will hard-
# fail the install too. If that strands you, the escape is `npm install --engine-strict=false` (or
# `npm_config_engine_strict=false`) — not deleting this file, which would restore the silent-warning
# behaviour this exists to prevent.
engine-strict=true

# Supply chain: do not resolve a package version published in the last 7 days. The npm
# compromise pattern is a malicious version published to a legitimate package and pulled in
# within hours — a release-age floor removes that window without pinning anything. `npm ci`
# is unaffected (the lockfile already fixes versions); this governs `npm install`/updates.
# Requires npm >= 11.10; this scaffold's Node 24 floor ships npm 11.16+.
# Flagged by the kit's own emitted SAST the moment this file was introduced.
min-release-age=7
